<?xml version="1.0" encoding="utf-8"?>
<model version="NetLogo 7.0.3" snapToGrid="true">
  <code><![CDATA[;; ============================================================
;;  CORPORATE SIMULATION — Agent-Based Model  v7
;;  Breeds: juniors (J), mids (M), seniors (S), managers (P)
;;
;;  Changes from v6:
;;    - Scaled cost raises by class multiplier + experience
;;    - Smooth per-tick raises (no lump sum every 100 ticks)
;;    - Hard pyramid caps: max-mids <= 5x seniors,
;;                         max-juniors <= 5x mids
;;    - Budget doubling decoupled from hiring thresholds
;;      via budget-expansion-margin + budget-expansion-cooldown
;;    - non-managers refreshed just before fatigue phase
;;    - file-close guard in init-log
;;    - current-maximal-cost internal variable (slider untouched)
;; ============================================================

breed [juniors  junior ]
breed [mids     mid    ]
breed [seniors  senior ]
breed [managers manager]

juniors-own  [ experience  fatigue  cost  profit  promotion-ready ]
mids-own     [ experience  fatigue  cost  profit  promotion-ready ]
seniors-own  [ experience  fatigue  cost  profit ]
managers-own [ cost ]

globals [
  ;; Population counts
  j-count  m-count  s-count

  ;; Fatigue death counters
  j-deaths  m-deaths  s-deaths

  ;; Budget firing counters
  j-fired  m-fired  s-fired

  ;; Promotion counters
  j-to-m-promotions
  m-to-s-promotions

  ;; Budget & Profit
  total-cost
  total-profit
  current-maximal-cost

  ;; Hiring cooldown trackers
  last-hire-tick-j
  last-hire-tick-m
  last-hire-tick-s

  ;; Budget expansion cooldown
  last-budget-expansion-tick

  ;; Dynamic workforce caps
  dynamic-max-juniors
  dynamic-max-mids
  dynamic-max-seniors
  last-expansion-tick

  ;; Per-tick vacancy counters
  m-vacancies
  s-vacancies

  ;; Cached non-manager agentset
  non-managers

  ;; Logging
  logging-active
  
  
]

;; ============================================================
;;  SETUP
;; ============================================================

to setup
  clear-all

  set j-deaths                 0
  set m-deaths                 0
  set s-deaths                 0
  set j-fired                  0
  set m-fired                  0
  set s-fired                  0
  set j-to-m-promotions        0
  set m-to-s-promotions        0
  set total-cost               0
  set total-profit             0
  set last-hire-tick-j        -1
  set last-hire-tick-m        -1
  set last-hire-tick-s        -1
  set last-budget-expansion-tick -1
  set m-vacancies              0
  set s-vacancies              0
  set last-expansion-tick     -1

  ;; Seed internal budget from slider — slider never touched again
  set current-maximal-cost maximal-cost

  ;; Seed dynamic caps from sliders — grow from here
  set dynamic-max-seniors max-seniors
  set dynamic-max-mids    max-mids
  set dynamic-max-juniors max-juniors

  create-juniors  initial-juniors [ setup-junior  ]
  create-mids     initial-mids    [ setup-mid     ]
  create-seniors  initial-seniors [ setup-senior  ]
  create-managers 1               [ setup-manager ]

  ;; Initial metric pass
  set non-managers (turtle-set juniors mids seniors)
  set j-count      count juniors
  set m-count      count mids
  set s-count      count seniors
  set total-cost   compute-cost
  set total-profit compute-profit

  init-log
  reset-ticks
end

;; ---- Per-breed initializers --------------------------------

to setup-junior
  set experience      0
  set fatigue         initial-fatigue-j
  set cost            initial-cost-j
  set profit          0
  set promotion-ready false
  setxy random-xcor random-ycor
  set color  yellow
  set shape  "person"
  set size   1.0
end

to setup-mid
  set experience      0
  set fatigue         initial-fatigue-m
  set cost            initial-cost-m
  set profit          0
  set promotion-ready false
  setxy random-xcor random-ycor
  set color  orange
  set shape  "person"
  set size   1.2
end

to setup-senior
  set experience 0
  set fatigue    initial-fatigue-s
  set cost       initial-cost-s
  set profit     0
  setxy random-xcor random-ycor
  set color  sky
  set shape  "person"
  set size   1.4
end

to setup-manager
  set cost 0
  setxy random-xcor random-ycor
  set color  red
  set shape  "person"
  set size   1.8
end

;; ============================================================
;;  REPORTERS — single-pass cost and profit
;; ============================================================

to-report compute-cost
  let base-cost sum [ cost ] of juniors +
                sum [ cost ] of mids    +
                sum [ cost ] of seniors
  let space-cost (count juniors + count mids + count seniors)
                 * employee-space-cost
  report base-cost + space-cost
end

to-report compute-profit
  report sum [ profit ] of juniors +
         sum [ profit ] of mids    +
         sum [ profit ] of seniors
end

;; ============================================================
;;  MAIN LOOP
;; ============================================================

to go
  ;; Reset per-tick counters
  set m-vacancies 0
  set s-vacancies 0

  ;; 1. Movement (local-first)
  ask juniors  [ move-junior  ]
  ask mids     [ move-mid     ]
  ask seniors  [ move-senior  ]
  ask managers [ move-manager ]

  ;; 2. Interactions (manager-boosted XP)
  ask juniors [ interact-as-junior ]
  ask mids    [ interact-as-mid    ]

  ;; 3. Mark promotion-ready (one-time flag + fatigue doubling)
  mark-promotion-ready

  ;; 4. Refresh non-managers just before fatigue phase
  ;;    so newly created agents are always included in morale hits
  set non-managers (turtle-set juniors mids seniors)

  ;; 5. Fatigue / death (morale hit + vacancy tracking)
  ask juniors [ check-fatigue-junior ]
  ask mids    [ check-fatigue-mid    ]
  ask seniors [ check-fatigue-senior ]

  ;; 6. Per-agent profit (single pass)
  compute-profits

  ;; 7. Smooth scaled cost raise — every tick, no lump sums
  increase-costs

  ;; 8. Population floor / ceiling
  enforce-limits

  ;; 9. Budget enforcement (incremental)
  enforce-budget

  ;; 10. Fill promotion vacancies (best profit first)
  fill-promotions

  ;; 11. Budget self-regulation (decoupled expand vs downsize)
  maximal-cost-self-regulation

  ;; 12. Tiered profit-based hiring (sensitive thresholds)
  profit-based-hiring

  ;; 13. Dynamic cap expansion (pyramid-clamped)
  adjust-max-employees

  ;; 14. Single metric refresh at end of tick
  set j-count      count juniors
  set m-count      count mids
  set s-count      count seniors
  set total-cost   compute-cost
  set total-profit compute-profit

  ;; 15. Plots + CSV
  do-plots
  log-tick-data

  tick
end

;; ============================================================
;;  MOVEMENT — local-first, global scan only as fallback
;; ============================================================

to move-junior
  let local-mids mids in-radius seek-radius
  ifelse any? local-mids [
    face min-one-of local-mids [ distance myself ]
    fd 1
  ][
    let t min-one-of mids [ distance myself ]
    ifelse t != nobody [ face t  fd 1 ] [ wiggle ]
  ]
end

to move-mid
  let local-seniors seniors in-radius seek-radius
  ifelse any? local-seniors [
    face min-one-of local-seniors [ distance myself ]
    fd 1
  ][
    let t min-one-of seniors [ distance myself ]
    ifelse t != nobody [ face t  fd 1 ] [ wiggle ]
  ]
end

to move-senior
  let boss one-of managers
  ifelse boss != nobody [ face boss  rt 180  fd 1 ] [ wiggle ]
end

to move-manager
  let local-seniors seniors in-radius seek-radius
  ifelse any? local-seniors [
    face min-one-of local-seniors [ distance myself ]
    fd 1
  ][
    let t min-one-of seniors [ distance myself ]
    ifelse t != nobody [ face t  fd 1 ] [ wiggle ]
  ]
end

to wiggle
  rt random-float 60 - 30
  fd 1
end

;; ============================================================
;;  INTERACTIONS — manager presence boosts XP
;; ============================================================

to interact-as-junior
  let nearby-mids mids in-radius interaction-radius
  if any? nearby-mids [
    let xp-gain ifelse-value (any? managers in-radius manager-radius)
                             [ 1 + manager-effectiveness-boost ] [ 1 ]
    set experience experience + xp-gain
    ask nearby-mids [ set fatigue fatigue + fatigue-increment ]
  ]
end

to interact-as-mid
  let nearby-seniors seniors in-radius interaction-radius
  if any? nearby-seniors [
    let xp-gain ifelse-value (any? managers in-radius manager-radius)
                             [ 1 + manager-effectiveness-boost ] [ 1 ]
    set experience experience + xp-gain
    ask nearby-seniors [ set fatigue fatigue + fatigue-increment ]
  ]
end

;; ============================================================
;;  PROMOTION READINESS
;;  One-time trigger: fatigue doubles, agent turns lime.
;;  Actual promotion waits for a vacancy above.
;; ============================================================

to mark-promotion-ready
  ask juniors with [ not promotion-ready and
                     experience >= j-experience-threshold ] [
    set fatigue         fatigue * 2
    set promotion-ready true
    set color           lime
  ]
  ask mids with [ not promotion-ready and
                  experience >= m-experience-threshold ] [
    set fatigue         fatigue * 2
    set promotion-ready true
    set color           lime
  ]
end

;; ============================================================
;;  FATIGUE / DEATH
;;  Guard: only draw random-normal if fatigue already exceeds
;;         resilience threshold (cheap check first).
;;  Morale hit uses cached non-managers agentset.
;;  M and S deaths open a promotion vacancy.
;; ============================================================

to check-fatigue-junior
  if fatigue > fatigue-resilience [
    let stress random-normal 0 fatigue-std
    if stress > fatigue [
      ask (non-managers in-radius morale-hit-radius)
          with [ self != myself ] [
        set fatigue fatigue + morale-hit-amount
      ]
      set j-deaths j-deaths + 1
      die
    ]
  ]
end

to check-fatigue-mid
  if fatigue > fatigue-resilience [
    let stress random-normal 0 fatigue-std
    if stress > fatigue [
      ask (non-managers in-radius morale-hit-radius)
          with [ self != myself ] [
        set fatigue fatigue + morale-hit-amount
      ]
      set m-vacancies m-vacancies + 1
      set m-deaths    m-deaths    + 1
      die
    ]
  ]
end

to check-fatigue-senior
  if fatigue > fatigue-resilience [
    let stress random-normal 0 fatigue-std
    if stress > fatigue [
      ask (non-managers in-radius morale-hit-radius)
          with [ self != myself ] [
        set fatigue fatigue + morale-hit-amount
      ]
      set s-vacancies s-vacancies + 1
      set s-deaths    s-deaths    + 1
      die
    ]
  ]
end

;; ============================================================
;;  PROFIT SYSTEM
;;  profit = (experience / 10) + class-multiplier * cost
;;  Multipliers: J=1  M=2  S=4
;; ============================================================

to compute-profits
  ask juniors [ set profit (experience / 10) + 1 * cost ]
  ask mids    [ set profit (experience / 10) + 2 * cost ]
  ask seniors [ set profit (experience / 10) + 4 * cost ]
end

;; ============================================================
;;  COST RAISE — smooth, scaled by class and experience
;;
;;  raise-per-tick = (cost-increase / 100)
;;                  * class-multiplier
;;                  * (1 + experience / experience-cost-scale)
;;
;;  Applied every tick instead of a lump sum every 100 ticks.
;;  class-multiplier: J=1  M=2  S=4
;;  experience-cost-scale: slider dampening XP contribution
;; ============================================================

to increase-costs
  ask juniors [
    set cost cost + (cost-increase / 100) * 1
                  * (1 + experience / experience-cost-scale)
  ]
  ask mids [
    set cost cost + (cost-increase / 100) * 2
                  * (1 + experience / experience-cost-scale)
  ]
  ask seniors [
    set cost cost + (cost-increase / 100) * 4
                  * (1 + experience / experience-cost-scale)
  ]
end

;; ============================================================
;;  BUDGET ENFORCEMENT — incremental, no repeated full sum
;;  Subtracts each fired agent's cost directly from running-cost.
;;  M and S firings open a promotion vacancy.
;; ============================================================

to enforce-budget
  let running-cost compute-cost

  while [ running-cost > current-maximal-cost ] [
    let cost-removed 0

    if count juniors > min-juniors [
      let victim min-one-of juniors [ profit ]
      if victim != nobody [
        set cost-removed cost-removed + [cost] of victim
                                      + employee-space-cost
        ask victim [ set j-fired j-fired + 1  die ]
      ]
    ]

    if count mids > min-mids [
      let victim min-one-of mids [ profit ]
      if victim != nobody [
        set cost-removed cost-removed + [cost] of victim
                                      + employee-space-cost
        ask victim [
          set m-vacancies m-vacancies + 1
          set m-fired     m-fired     + 1
          die
        ]
      ]
    ]

    if count seniors > min-seniors [
      let victim min-one-of seniors [ profit ]
      if victim != nobody [
        set cost-removed cost-removed + [cost] of victim
                                      + employee-space-cost
        ask victim [
          set s-vacancies s-vacancies + 1
          set s-fired     s-fired     + 1
          die
        ]
      ]
    ]

    set running-cost running-cost - cost-removed

    ;; Safety exits
    if cost-removed = 0 [ stop ]
    if (count juniors <= min-juniors) and
       (count mids    <= min-mids   ) and
       (count seniors <= min-seniors) [ stop ]
  ]
end

;; ============================================================
;;  VACANCY-TRIGGERED PROMOTION
;;  Best-profit promotion-ready agent fills each vacancy.
;;  Agentset refreshed after each individual promotion.
;; ============================================================

to fill-promotions
  ;; --- J -> M ---
  let ready-js juniors with [ promotion-ready ]
  let slots-m  min list m-vacancies (count ready-js)
  repeat slots-m [
    if any? ready-js [
      ask max-one-of ready-js [ profit ] [
        let px xcor  let py ycor
        hatch-mids 1 [
          set experience      0
          set fatigue         initial-fatigue-m
          set cost            initial-cost-m
          set profit          0
          set promotion-ready false
          set color  orange  set shape "person"  set size 1.2
          setxy px py
        ]
        set j-to-m-promotions j-to-m-promotions + 1
        die
      ]
      set ready-js juniors with [ promotion-ready ]
    ]
  ]

  ;; --- M -> S ---
  let ready-ms mids with [ promotion-ready ]
  let slots-s  min list s-vacancies (count ready-ms)
  repeat slots-s [
    if any? ready-ms [
      ask max-one-of ready-ms [ profit ] [
        let px xcor  let py ycor
        hatch-seniors 1 [
          set experience 0
          set fatigue    initial-fatigue-s
          set cost       initial-cost-s
          set profit     0
          set color  sky  set shape "person"  set size 1.4
          setxy px py
        ]
        set m-to-s-promotions m-to-s-promotions + 1
        die
      ]
      set ready-ms mids with [ promotion-ready ]
    ]
  ]
end

;; ============================================================
;;  BUDGET SELF-REGULATION
;;  Expansion uses budget-expansion-margin (high) +
;;  budget-expansion-cooldown — completely decoupled from
;;  hiring thresholds which are much more sensitive.
;;  Downsizing remains reactive with no cooldown.
;; ============================================================

to maximal-cost-self-regulation
  if (total-profit - total-cost) > (budget-expansion-margin * current-maximal-cost) and
     (ticks - last-budget-expansion-tick) >= budget-expansion-cooldown [
    set current-maximal-cost       current-maximal-cost * 2
    set last-budget-expansion-tick ticks
  ]

  if (total-profit - total-cost) < (profit-margin * total-cost) and ticks > 100 [
    set current-maximal-cost current-maximal-cost * downsize-rate
  ]
end

;; ============================================================
;;  TIERED PROFIT-BASED HIRING — uses sensitive thresholds
;;  hire-profit-threshold-* sit well below budget-expansion-margin
;;  so hiring fires many ticks before any budget doubling occurs.
;; ============================================================

to profit-based-hiring
  if total-profit  > hire-profit-threshold-j and
     total-cost    < current-maximal-cost    and
     count juniors < dynamic-max-juniors     and
     (ticks - last-hire-tick-j) >= hiring-cooldown [
    create-juniors 1 [ setup-junior ]
    set last-hire-tick-j ticks
  ]

  if total-profit > hire-profit-threshold-m and
     total-cost   < current-maximal-cost    and
     count mids   < dynamic-max-mids        and
     (ticks - last-hire-tick-m) >= hiring-cooldown [
    create-mids 1 [ setup-mid ]
    set last-hire-tick-m ticks
  ]

  if total-profit  > hire-profit-threshold-s and
     total-cost    < current-maximal-cost    and
     count seniors < dynamic-max-seniors     and
     (ticks - last-hire-tick-s) >= hiring-cooldown [
    create-seniors 1 [ setup-senior ]
    set last-hire-tick-s ticks
  ]
end

;; ============================================================
;;  DYNAMIC WORKFORCE CAP EXPANSION
;;  Condition: total-profit > expansion-margin * total-cost
;;             AND expansion-cooldown elapsed
;;  Effect:    +1 senior cap, +5 mid cap, +25 junior cap
;;  After expansion, pyramid ratios are hard-clamped:
;;    dynamic-max-mids    <= dynamic-max-seniors * 5
;;    dynamic-max-juniors <= dynamic-max-mids    * 5
;;  Caps never fall below absolute minimums.
;; ============================================================

to adjust-max-employees
  if total-cost > 0 and total-profit > expansion-margin * total-cost [
    if (ticks - last-expansion-tick) >= expansion-cooldown [

      set dynamic-max-seniors dynamic-max-seniors + 1
      set dynamic-max-mids    dynamic-max-mids    + 5
      set dynamic-max-juniors dynamic-max-juniors + 25

      ;; Hard pyramid clamp — applied immediately after every expansion
      set dynamic-max-mids
        min list dynamic-max-mids (dynamic-max-seniors * 5)
      set dynamic-max-juniors
        min list dynamic-max-juniors (dynamic-max-mids * 5)

      ;; Never drop below absolute minimums
      set dynamic-max-mids    max list dynamic-max-mids    min-mids
      set dynamic-max-juniors max list dynamic-max-juniors min-juniors

      set last-expansion-tick ticks
    ]
  ]
end

;; ============================================================
;;  POPULATION FLOOR / CEILING — uses dynamic caps
;; ============================================================

to enforce-limits
  while [ count juniors < min-juniors ] [ create-juniors 1 [ setup-junior ] ]
  if count juniors > dynamic-max-juniors [
    ask n-of (count juniors - dynamic-max-juniors) juniors [ die ]
  ]

  while [ count mids < min-mids ] [ create-mids 1 [ setup-mid ] ]
  if count mids > dynamic-max-mids [
    ask n-of (count mids - dynamic-max-mids) mids [ die ]
  ]

  while [ count seniors < min-seniors ] [ create-seniors 1 [ setup-senior ] ]
  if count seniors > dynamic-max-seniors [
    ask n-of (count seniors - dynamic-max-seniors) seniors [ die ]
  ]
end

;; ============================================================
;;  PLOTS
;;  Requires four plots in the Interface:
;;    "Population"     pens: juniors / mids / seniors
;;    "Financials"     pens: profit / cost
;;    "Events"         pens: j-deaths / m-deaths / s-deaths /
;;                           j-fired / m-fired / s-fired /
;;                           j-to-m / m-to-s
;;    "Workforce Caps" pens: max-j / max-m / max-s
;; ============================================================

to do-plots
  set-current-plot "Population"
  set-current-plot-pen "juniors"  plot j-count
  set-current-plot-pen "mids"     plot m-count
  set-current-plot-pen "seniors"  plot s-count

  set-current-plot "Financials"
  set-current-plot-pen "profit"  plot total-profit
  set-current-plot-pen "cost"    plot total-cost

end

;; ============================================================
;;  CSV LOGGING
;;  File stays open between ticks — no open/close overhead.
;;  init-log  : safely closes any open handle, deletes old file,
;;              opens fresh file, writes header.
;;  log-tick-data : writes one row per tick (no open/close).
;;  stop-logging  : closes file safely before ending a run.
;; ============================================================

to init-log
  ;; Safely close any open handle before touching the file
  carefully [ file-close ] []
  if file-exists? "simulation_log.csv" [ file-delete "simulation_log.csv" ]
  file-open "simulation_log.csv"
  file-print (word
    "tick,"
    "j-count,m-count,s-count,"
    "total-cost,total-profit,"
    "current-maximal-cost,"
    "j-deaths,m-deaths,s-deaths,"
    "j-fired,m-fired,s-fired,"
    "j-to-m-promotions,m-to-s-promotions,"
    "m-vacancies,s-vacancies,"
    "dynamic-max-juniors,dynamic-max-mids,dynamic-max-seniors"
  )
  ;; File intentionally left open for efficient per-tick writes
  set logging-active true
end

to log-tick-data
  if not logging-active [ stop ]
  file-print (word
    ticks               ","
    j-count             "," m-count             "," s-count             ","
    total-cost          "," total-profit         ","
    current-maximal-cost ","
    j-deaths            "," m-deaths             "," s-deaths            ","
    j-fired             "," m-fired              "," s-fired             ","
    j-to-m-promotions   "," m-to-s-promotions    ","
    m-vacancies         "," s-vacancies          ","
    dynamic-max-juniors "," dynamic-max-mids     "," dynamic-max-seniors
  )
end

to stop-logging
  set logging-active false
  file-close
  print "Logging stopped. File saved as simulation_log.csv"
end
]]></code>
  <widgets>
    <view x="515" wrappingAllowedX="true" y="3" frameRate="30.0" minPycor="-16" height="439" showTickCounter="true" patchSize="13.2" fontSize="10" wrappingAllowedY="true" width="439" tickCounterLabel="ticks" maxPycor="16" updateMode="0" maxPxcor="16" minPxcor="-16"></view>
    <slider x="0" step="1" y="5" max="100" width="250" display="initial-juniors" height="50" min="0" direction="Horizontal" default="35.0" variable="initial-juniors"></slider>
    <slider x="255" step="0.01" y="5" max="1" width="250" display="initial-fatigue-j" height="50" min="0" direction="Horizontal" default="0.15" variable="initial-fatigue-j"></slider>
    <slider x="0" step="1" y="60" max="100" width="250" display="initial-mids" height="50" min="0" direction="Horizontal" default="10.0" variable="initial-mids"></slider>
    <slider x="255" step="0.01" y="60" max="1" width="250" display="initial-fatigue-m" height="50" min="0" direction="Horizontal" default="0.25" variable="initial-fatigue-m"></slider>
    <slider x="0" step="1" y="115" max="100" width="250" display="initial-seniors" height="50" min="0" direction="Horizontal" default="5.0" variable="initial-seniors"></slider>
    <slider x="255" step="0.01" y="115" max="1" width="250" display="initial-fatigue-s" height="50" min="0" direction="Horizontal" default="0.35" variable="initial-fatigue-s"></slider>
    <slider x="0" step="1" y="170" max="100" width="250" display="interaction-radius" height="50" min="0" direction="Horizontal" default="8.0" variable="interaction-radius"></slider>
    <slider x="255" step="1" y="170" max="100" width="250" display="min-juniors" height="50" min="0" direction="Horizontal" default="60.0" variable="min-juniors"></slider>
    <slider x="0" step="1" y="225" max="100" width="250" display="j-experience-threshold" height="50" min="0" direction="Horizontal" default="25.0" variable="j-experience-threshold"></slider>
    <slider x="255" step="1" y="225" max="100" width="250" display="max-juniors" height="50" min="0" direction="Horizontal" default="100.0" variable="max-juniors"></slider>
    <slider x="0" step="1" y="280" max="100" width="250" display="m-experience-threshold" height="50" min="0" direction="Horizontal" default="30.0" variable="m-experience-threshold"></slider>
    <slider x="255" step="1" y="280" max="100" width="250" display="min-mids" height="50" min="0" direction="Horizontal" default="10.0" variable="min-mids"></slider>
    <slider x="0" step="0.05" y="335" max="1" width="250" display="fatigue-std" height="50" min="0" direction="Horizontal" default="0.75" variable="fatigue-std"></slider>
    <slider x="255" step="1" y="335" max="100" width="250" display="max-mids" height="50" min="0" direction="Horizontal" default="25.0" variable="max-mids"></slider>
    <slider x="0" step="0.05" y="390" max="1" width="250" display="fatigue-resilience" height="50" min="0" direction="Horizontal" default="0.75" variable="fatigue-resilience"></slider>
    <slider x="255" step="1" y="390" max="100" width="250" display="min-seniors" height="50" min="0" direction="Horizontal" default="5.0" variable="min-seniors"></slider>
    <slider x="0" step="0.01" y="445" max="1" width="250" display="fatigue-increment" height="50" min="0" direction="Horizontal" default="0.18" variable="fatigue-increment"></slider>
